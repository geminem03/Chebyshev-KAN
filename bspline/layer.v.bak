module layer #(
    parameter NUM_PES = 64,
    parameter MEM_DEPTH = 384
)(
    input  wire clk,
    input  wire rst_n,

    // Control
    input  wire start,
    input  wire last,              // Assert with start on the last input of a GEMV pass
    input  wire [15:0] x,
    output wire ready,
	output wire debug_bit // TODO: remove once modules not optimized away

);

	// Outputs from PE column
	// Not an output since that takes too many I/O pins
	// that are available to the top-level module
	// TODO: add requant blocks, feed accum results to that
	// and write requant output to m20k
	(* keep *) wire [NUM_PES*64-1:0] pe_accum_results;
	
    // remove this later
	assign debug_bit = ^pe_accum_results;
	 
	 

    // rst_n --> registered synchronous clear for DSP slices in PEs
    reg sclr;

    always @(posedge clk) begin
        sclr <= !rst_n;
    end

    // ------------------------------------------------------------
    // Wires between bspline_basis and pe_column
    // ------------------------------------------------------------
    wire signed [26:0] basis_data;
    wire basis_valid;
    wire [2:0] out_stride;

    wire basis_done;

    // ------------------------------------------------------------
    // bspline_basis instance
    // ------------------------------------------------------------
    bspline_basis u_basis (
        .clk(clk),
        .rst_n(rst_n),
        .start(start),
        .last(last),
        .ready(ready),
        .x(x),
        .out_data(basis_data),
        .out_valid(basis_valid),
        .out_stride(out_stride),
        .out_done(basis_done)
    );

    // ------------------------------------------------------------
    // pe_column instance
    // ------------------------------------------------------------
    // Only feed data when valid, otherwise inject zero
    pe_column #(
        .NUM_PES(NUM_PES),
        .MEM_DEPTH(MEM_DEPTH),
        .COL_INDEX(0),
        .INPUT_WIDTH(27),
        .ACC_WIDTH(64)
    ) u_pe_column (
        .clk(clk),
        .sclr(sclr),
        .valid_in(basis_valid),
        .stride_in(out_stride),
        .data_in(basis_valid ? basis_data : 27'sd0),
        .done_in(basis_done),
        .all_acc_results(pe_accum_results)
    );

endmodule
